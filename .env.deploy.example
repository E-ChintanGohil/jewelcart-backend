# Backend deployment credentials (gitignored — copy to .env.deploy and fill in)
# Used by: npm run deploy

SSH_HOST=5.189.145.209
SSH_USER=root
SSH_PASS=

# Where the backend lives on the VPS
REMOTE_PATH=/var/www/jewelcart-backend

# pm2 process name (run `pm2 list` on the VPS to find it)
PM2_NAME=jewelcart-backend

# Git branch to pull
GIT_BRANCH=main
