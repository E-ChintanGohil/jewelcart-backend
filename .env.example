# Database
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=jewelcart
DB_PORT=3306
DATABASE_URL="mysql://root:your_password@localhost:3306/jewelcart"

# Server
PORT=5001
NODE_ENV=development

# JWT
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRES_IN=7d

# Frontend (for CORS)
FRONTEND_URL=http://localhost:5000

# Razorpay
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# Email (SMTP) — for order notifications and password reset
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="JewelCart <your-email@gmail.com>"

# Assets — base URL used when building image URLs (set to your cPanel domain in production)
ASSETS_BASE_URL=http://localhost:5001
